---
import { site, footerAreas, homeServices } from "../data/site.js";
import { serviceBySlug } from "../data/services.js";
import Icon from "./Icon.astro";
const svc = homeServices.map((s) => serviceBySlug[s]);
const year = 2026;
const areaSlug = (n) => `/pest-control-${n.toLowerCase().replace(/\s+/g, "-")}/`;
---
<footer class="foot">
  <div class="wrap foot-top">
    <div class="foot-brand">
      <div class="foot-logo">
        <svg viewBox="0 0 40 40" width="34" height="34" aria-hidden="true">
          <circle cx="20" cy="20" r="19" fill="#AEC94B"/>
          <path d="M13 27c-1-7 3-13 15-14 1 9-4 15-11 15-1.4 0-2.6-.4-2.6-.4Z" fill="#22331F"/>
          <path d="M16 24c2.6-2.6 5.4-4 8-4.6" stroke="#AEC94B" stroke-width="1.6" fill="none" stroke-linecap="round"/>
        </svg>
        <span><b>East Lansing</b><span>Pest Control</span></span>
      </div>
      <p>Local pest control for East Lansing and the greater Lansing area. Ants, spiders, rodents, mosquitoes, ticks, and bed bugs, handled with a plan built for the Michigan seasons.</p>
      <a href={site.phoneHref} class="btn btn--pill btn--lg"><Icon name="phone" cls="ic" /> Call {site.phone}</a>
      <p class="foot-hours"><Icon name="clock" cls="ic" /> {site.hoursLine}</p>
    </div>

    <div class="foot-col">
      <h4>Pest Services</h4>
      <ul>
        {svc.map((s) => (<li><a href={`/${s.slug}/`}>{s.label}</a></li>))}
        <li><a href="/pest-library/">Pest Library</a></li>
      </ul>
    </div>

    <div class="foot-col">
      <h4>Company</h4>
      <ul>
        <li><a href="/services/">Pest Control</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/privacy-policy/">Privacy Policy</a></li>
      </ul>
    </div>

    <div class="foot-areas">
      <h4>Service Area</h4>
      <ul class="foot-area-list">
        {footerAreas.map((n) => (<li><a href={areaSlug(n)}><Icon name="pin" cls="ic" /> {n}, MI</a></li>))}
      </ul>
    </div>
  </div>

  <div class="wrap foot-legal">
    <p class="foot-disc">{site.brand} is a free service to assist homeowners in connecting with local service providers. All contractors/providers are independent and {site.brand} does not warrant or guarantee any work performed. It is the responsibility of the homeowner to verify that the hired contractor furnishes the necessary license and insurance required for the work being performed. All persons depicted in a photo or video are actors or models and not contractors listed on {site.brand}.</p>
    <p class="foot-copy">© {year} {site.brand} · {site.city}, {site.region}</p>
  </div>
</footer>
