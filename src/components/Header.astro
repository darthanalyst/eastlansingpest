---
import { site, homeServices } from "../data/site.js";
import { serviceBySlug } from "../data/services.js";
import { pestPages } from "../data/pests.js";
import Icon from "./Icon.astro";
const svc = homeServices.map((s) => serviceBySlug[s]);
---
<div class="promobar">
  <div class="wrap promobar-in">
    <span>Serving East Lansing and the greater Lansing area · Same-day help available</span>
    <a href={site.phoneHref} class="promo-call"><Icon name="phone" cls="ic" /> {site.phone}</a>
  </div>
</div>

<header class="head">
  <div class="wrap head-in">
    <a href="/" class="brand" aria-label={site.brand}>
      <span class="brand-mark">
        <svg viewBox="0 0 40 40" width="38" height="38" aria-hidden="true">
          <circle cx="20" cy="20" r="19" fill="#AEC94B"/>
          <path d="M13 27c-1-7 3-13 15-14 1 9-4 15-11 15-1.4 0-2.6-.4-2.6-.4Z" fill="#2E4A38"/>
          <path d="M16 24c2.6-2.6 5.4-4 8-4.6" stroke="#AEC94B" stroke-width="1.6" fill="none" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="brand-tx"><b>East Lansing</b><span>Pest Control</span></span>
    </a>

    <nav class="nav" aria-label="Primary">
      <div class="nav-drop">
        <a href="/services/" class="nav-link">Pest Control <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></a>
        <div class="drop-menu drop-menu--wide">
          <span class="drop-head">Services</span>
          {svc.map((s) => (<a href={`/${s.slug}/`}><Icon name={s.icon} cls="ic" /><span>{s.label}</span></a>))}
          <span class="drop-head">Common pests</span>
          <div class="drop-pests">
            {pestPages.map((p) => (<a href={`/pest-library/${p.slug}/`}><Icon name={p.icon} cls="ic" /><span>{p.name}</span></a>))}
          </div>
        </div>
      </div>
      <a href="/pest-control-okemos/" class="nav-link">Service Area</a>
      <a href="/pest-library/" class="nav-link">Pest Library</a>
      <a href="/about/" class="nav-link">About</a>
      <a href="/contact/" class="nav-link">Contact</a>
    </nav>

    <a href={site.phoneHref} class="btn btn--pill nav-cta"><Icon name="phone" cls="ic" /> {site.phone}</a>

    <button class="burger" aria-label="Open menu" onclick="document.getElementById('mnav').classList.toggle('open')">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="mnav" id="mnav">
  {svc.map((s) => (<a href={`/${s.slug}/`}>{s.label}</a>))}
  <a href="/services/">All Pest Services</a>
  <span class="mnav-head">Common pests</span>
  {pestPages.map((p) => (<a href={`/pest-library/${p.slug}/`}>{p.name}</a>))}
  <a href="/pest-control-okemos/">Service Area</a>
  <a href="/pest-library/">Pest Library</a>
  <a href="/about/">About</a>
  <a href="/contact/">Contact</a>
  <a href={site.phoneHref} class="mnav-call">Call {site.phone}</a>
</div>
