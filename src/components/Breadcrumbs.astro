---
const { items = [] } = Astro.props;
---
<nav class="crumbs" aria-label="Breadcrumb">
  <div class="wrap">
    <ol>
      {items.map((it, i) => (
        <li>{i < items.length - 1 ? (<a href={it.path}>{it.name}</a>) : (<span aria-current="page">{it.name}</span>)}{i < items.length - 1 && <span class="crumbs-sep" aria-hidden="true">/</span>}</li>
      ))}
    </ol>
  </div>
</nav>
