---
const { faqs = [], title = "Ask the pest experts", sub = "Common questions about pest control in East Lansing." } = Astro.props;
---
<section class="faq" id="faq">
  <div class="wrap">
    <div class="sec-head">
      <span class="overline overline--c">FAQ</span>
      <h2>{title}</h2>
      <p>{sub}</p>
    </div>
    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary><span>{f.q}</span><span class="faq-plus" aria-hidden="true"></span></summary>
          <div class="faq-a"><p>{f.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>
